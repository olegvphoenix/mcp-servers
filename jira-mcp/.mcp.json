{
  "mcpServers": {
    "jira": {
      "command": "python",
      "args": ["server.py"],
      "env": {
        "JIRA_URL": "${JIRA_URL}",
        "JIRA_USERNAME": "${JIRA_USERNAME}",
        "JIRA_PASSWORD": "${JIRA_PASSWORD}",
        "JIRA_DEFAULT_PROJECT": "${JIRA_DEFAULT_PROJECT}",
        "JIRA_DEFAULT_ISSUE_TYPE": "${JIRA_DEFAULT_ISSUE_TYPE}",
        "JIRA_DEFAULT_CUSTOM_FIELDS": "${JIRA_DEFAULT_CUSTOM_FIELDS}"
      }
    }
  }
}
